# Telegram i Ollama
TELEGRAM_BOT_TOKEN=
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_BACKEND=auto
OLLAMA_CHAT_MODEL=qooba/bielik-1.5b-v3.0-instruct:Q8_0
OLLAMA_EMBED_MODEL=nomic-embed-text

# true = modele Hugging Face; false = jawny tryb demonstracyjny (regex/heurystyki)
USE_PRIVACY_MODEL=false
USE_BIELIK_GUARD=false
PRIVACY_MODEL=openai/privacy-filter
BIELIK_GUARD_MODEL=speakleash/Bielik-Guard-0.1B-v1.1

# mask: zamaskuj i kontynuuj; block: zatrzymaj wiadomość zawierającą PII
PII_POLICY=mask
SAFETY_THRESHOLD=0.65
RAG_TOP_K=3
RAG_MIN_SCORE=0.08
VECTOR_DB_PATH=data/vector_store.sqlite3
AUDIT_LOG_PATH=data/audit.jsonl
MAX_INPUT_CHARS=4000
BLOCK_PROMPT_INJECTION=true
